        "deploy": {
          "pipeline": [
            "fetch_artifact",
            "remote_script",
            "stop",
            "backup",
            "install",
            "start",
            "health_check",
            "verify"
          ],
          "rollback_pipeline": [
            "stop",
            "rollback",
            "start",
            "health_check",
            "verify"
          ],
          "target": "homelab"
        },
        "description": "Ursa Major C2 server on the blink homelab host",
        "health_check": {
          "interval": 3,
          "timeout": 90,
          "url": "https://{{publish_host}}:{{c2_port}}/health"
        },
        "install": {
          "dest": "runtime/ursa-major/staging/ursa-major-repo.tgz"
        },
        "remote_script": {
          "path": "deploy/blink/provision_ursa_major.sh"
        },
        "service_name": "ursa-major",
        "source": {
          "artifact": "dist/ursa-major-repo.tgz",
          "command": "mkdir -p dist && COPYFILE_DISABLE=1 COPY_EXTENDED_ATTRIBUTES_DISABLE=1 tar --no-mac-metadata --no-xattrs --no-acls --no-fflags -czf dist/ursa-major-repo.tgz --exclude=.git --exclude=.github --exclude=.mypy_cache --exclude=.pytest_cache --exclude=.ruff_cache --exclude=.venv --exclude=venv --exclude=build --exclude=dist --exclude=minor/build --exclude=major/ursa.db --exclude=major/tls .",
          "type": "local_build",
          "workdir": "."
        },
        "start": {
          "command": "rm -rf {{runtime_dir}}/repo && mkdir -p {{runtime_dir}}/repo && tar -xzf {{runtime_dir}}/staging/ursa-major-repo.tgz -C {{runtime_dir}}/repo && docker compose --env-file {{runtime_dir}}/.env -f {{runtime_dir}}/repo/deploy/ursa-major.compose.yaml up -d --build c2 web"
        },
        "stop": {
          "command": "if [ -f {{runtime_dir}}/.env ] && [ -f {{runtime_dir}}/repo/deploy/ursa-major.compose.yaml ]; then docker compose --env-file {{runtime_dir}}/.env -f {{runtime_dir}}/repo/deploy/ursa-major.compose.yaml down --remove-orphans; fi"
        },
        "verify": {
          "suite": "deploy/blink/suites/ursa_major_homelab.rb",
          "tags": [
            "smoke",
            "health"
          ],
          "tests": {
            "c2-container-running": {
              "command": "docker inspect --format '{{.State.Status}}' ursa-major-c2-1 2>/dev/null",
              "expect_output": "running",
              "tags": [
                "health"
              ],
              "type": "shell"
            },
            "c2-health": {
              "expect_body": "healthy",
              "expect_status": 200,
              "tags": [
                "smoke",
                "health"
              ],
              "type": "http",
              "url": "https://{{publish_host}}:{{c2_port}}/health"
            },
            "c2-port-published": {
              "command": "docker ps --filter name=^/ursa-major-c2-1$ --format '{{.Ports}}'",
              "expect_output": "/192\\.168\\.86\\.53:18443->8443\\/tcp/",
              "tags": [
                "health"
              ],
              "type": "shell"
            },
            "web-health": {
              "expect_body": "ursa-admin-api",
              "expect_status": 200,
              "tags": [
                "smoke",
                "health"
              ],
              "type": "http",
              "url": "http://{{publish_host}}:{{web_port}}/healthz"
            },
            "web-port-published": {
              "command": "docker ps --filter name=^/ursa-major-web-1$ --format '{{.Ports}}'",
              "expect_output": "/192\\.168\\.86\\.53:18080->8080\\/tcp/",
              "tags": [
                "health"
              ],
              "type": "shell"
            }
          }
        }
      },
      "source": {
        "artifact": "dist/ursa-major-repo.tgz",
        "command": "mkdir -p dist && COPYFILE_DISABLE=1 COPY_EXTENDED_ATTRIBUTES_DISABLE=1 tar --no-mac-metadata --no-xattrs --no-acls --no-fflags -czf dist/ursa-major-repo.tgz --exclude=.git --exclude=.github --exclude=.mypy_cache --exclude=.pytest_cache --exclude=.ruff_cache --exclude=.venv --exclude=venv --exclude=build --exclude=dist --exclude=minor/build --exclude=major/ursa.db --exclude=major/tls .",
        "type": "local_build",
        "workdir": "."
      },
      "target": {
        "base": "/home/admin/barelabs",
        "config": {
          "base": "/home/admin/barelabs",
          "c2_port": "18443",
          "compose_project": "ursa-major",
          "host": "blink",
          "image_name": "ursa-major:local",
          "publish_host": "192.168.86.53",
          "runtime_dir": "/home/admin/barelabs/runtime/ursa-major",
          "type": "ssh",
          "user": "admin",
          "web_port": "18080"
        },
        "description": "ssh://admin@blink",
        "name": "homelab",
        "type": "ssh"
      }
    }
  },
  "config_hash": "d0d6023c49ed0b2b0e27229112fa7fa272f87ab8bbbd0ab0229dd574395dfbf1"
}
